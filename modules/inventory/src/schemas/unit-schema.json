{
	"name": "unit",
	"fields": {
		"id": {
			"type": "string",
			"label": "ID",
			"hidden": true,
			"constraints": [{ "type": "length", "max": 36 }]
		},
		"orgId": {
			"type": "string",
			"label": "Organization",
			"hidden": true,
			"constraints": [{ "type": "length", "max": 36 }]
		},
		"name": {
			"type": "string",
			"label": "Unit Name",
			"required": { "create": true, "update": false },
			"constraints": [{ "type": "length", "min": 1, "max": 200 }]
		},
		"symbol": {
			"type": "string",
			"label": "Symbol",
			"required": { "create": false, "update": false },
			"constraints": [{ "type": "length", "min": 1, "max": 50 }]
		},
		"categoryId": {
			"type": "string",
			"label": "Unit Category",
			"required": { "create": false, "update": false },
			"constraints": [{ "type": "length", "max": 36 }]
		},
		"baseUnit": {
			"type": "string",
			"label": "Base Unit",
			"required": { "create": false, "update": false },
			"constraints": [{ "type": "length", "max": 100 }]
		},
		"multiplier": {
			"type": "integer",
			"label": "Multiplier",
			"required": { "create": false, "update": false },
			"constraints": [{ "type": "value_range", "min": 0 }]
		},
		"status": {
			"type": "string",
			"label": "Status",
			"required": { "create": false, "update": false }
		},
		"etag": {
			"type": "string",
			"label": "Etag",
			"hidden": true
		},
		"createdAt": {
			"type": "date",
			"label": "Created At",
			"hidden": false
		},
		"updatedAt": {
			"type": "date",
			"label": "Updated At",
			"hidden": false
		}
	}
}
