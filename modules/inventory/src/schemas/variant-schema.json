{
	"name": "variant",
	"fields": {
		"id": {
			"type": "string",
			"label": "ID",
			"hidden": true,
			"constraints": [{ "type": "length", "max": 36 }]
		},
		"name": {
			"type": "string",
			"label": "Name",
			"required": { "create": true, "update": false }
		},
		"sku": {
			"type": "string",
			"label": "SKU",
			"required": { "create": false, "update": false },
			"constraints": [{ "type": "length", "min": 1, "max": 100 }]
		},
		"barcode": {
			"type": "string",
			"label": "Barcode",
			"constraints": [{ "type": "length", "max": 100 }]
		},
		"proposedPrice": {
			"type": "integer",
			"label": "Proposed Price",
			"required": { "create": false, "update": false },
			"constraints": [{ "type": "value_range", "min": 0 }]
		},
		"imageUrl": {
			"type": "string",
			"label": "Image URL"
		},
		"status": {
			"type": "enum",
			"label": "Status",
			"required": { "create": false, "update": false },
			"constraints": [{ "type": "required" }],
			"enum": [
				{ "value": "active", "label": "Active" },
				{ "value": "inactive", "label": "Inactive" }
			]
		},
		"attributes": {
			"type": "object",
			"label": "Attributes",
			"hidden": true
		},
		"productId": {
			"type": "string",
			"label": "Product ID",
			"hidden": true
		},
		"etag": {
			"type": "string",
			"label": "Etag",
			"hidden": true
		},
		"createdAt": {
			"type": "date",
			"format": "date-time",
			"label": "Created At"
		},
		"updatedAt": {
			"type": "date",
			"format": "date-time",
			"label": "Updated At"
		}
	}
}
