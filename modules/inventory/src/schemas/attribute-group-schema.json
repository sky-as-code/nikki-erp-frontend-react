{
	"name": "attribute-group",
	"fields": {
		"id": {
			"type": "string",
			"label": "ID",
			"hidden": true,
			"constraints": [{ "type": "length", "max": 36 }]
		},
		"productId": {
			"type": "string",
			"label": "Product ID",
			"required": { "create": true, "update": true },
			"hidden": true
		},
		"name": {
			"type": "string",
			"label": "Name",
			"required": { "create": true, "update": true },
			"constraints": [{ "type": "length", "min": 1, "max": 200 }]
		},
		"index": {
			"type": "integer",
			"label": "Index",
			"required": { "create": false, "update": false },
			"constraints": [{ "type": "value_range", "min": 0 }]
		},
		"etag": {
			"type": "string",
			"label": "Etag",
			"hidden": true
		},
		"createdAt": {
			"type": "date",
			"format": "date-time",
			"label": "Created At"
		},
		"updatedAt": {
			"type": "date",
			"format": "date-time",
			"label": "Updated At"
		}
	}
}
